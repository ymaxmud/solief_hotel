NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=https://soliefhotel.vercel.app
SUPABASE_SERVICE_ROLE_KEY=
# Booking email. Two transports are supported; set ONE.
# Recipient(s) — comma-separated ok. Used by both transports.
BOOKING_EMAIL_TO=
BOOKING_EMAIL_CC=
HOTEL_OWNER_EMAIL=
# Option A (no third party): direct SMTP. For Gmail, create a Google App Password
# (Account > Security > 2-Step Verification > App passwords) and set:
#   SMTP_USER = your@gmail.com   SMTP_PASS = the 16-char app password
# Host/port default to Gmail (smtp.gmail.com:465). BOOKING_EMAIL_FROM defaults to SMTP_USER.
SMTP_USER=
SMTP_PASS=
SMTP_HOST=
SMTP_PORT=
# Option B: Resend API (needs a verified sender/domain).
RESEND_API_KEY=
BOOKING_EMAIL_FROM=
HOTEL_OWNER_WHATSAPP_E164=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
NEXT_PUBLIC_HOTEL_LAT=41.2683062
NEXT_PUBLIC_HOTEL_LNG=69.2038021
NEXT_PUBLIC_ATTENDANCE_RADIUS_METERS=150
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=
ALLOW_INITIAL_ADMIN_BOOTSTRAP=false
# Observability. Vercel Analytics + Speed Insights are enabled automatically on Vercel
# (no key needed). Sentry is optional and off unless a DSN is provided — see
# OBSERVABILITY_NOTES.md. If you add the DSN, also add it in Sentry env, not here in git.
NEXT_PUBLIC_SENTRY_DSN=
